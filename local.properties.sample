# Örnek yapılandırma — bu dosyayı `local.properties` olarak kopyalayıp doldurun.
# `local.properties` .gitignore'dadır; sırlar repoya GİRMEZ.
#
# Android SDK konumu (kendi makinenizde):
# sdk.dir=/path/to/Android/sdk
#
# Supabase (anon key tasarım gereği herkese açıktır; güvenlik RLS ile):
SECAL_SUPABASE_URL=YOUR_SUPABASE_URL
SECAL_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
#
# Google ile giriş — Google Cloud "Web" OAuth istemci kimliği (Supabase Google sağlayıcısıyla aynı):
SECAL_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID
